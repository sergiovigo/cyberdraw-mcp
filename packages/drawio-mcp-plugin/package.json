{
  "name": "drawio-mcp-plugin",
  "version": "2.2.0",
  "description": "Draw.io MCP Plugin - Browser plugin that runs inside Draw.io",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && esbuild src/plugin.ts --bundle --outfile=dist/mcp-plugin.js --format=iife --global-name=DrawMcp --target=chrome120",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "drawio",
    "diagrams.net",
    "plugin"
  ],
  "author": "Ladislav Gazo",
  "license": "MIT",
  "dependencies": {
    "cyberdraw-runtime-contract": "workspace:*",
    "drawio-mcp-compat": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "30.2.0",
    "esbuild": "0.25.12",
    "rimraf": "6.1.3",
    "typescript": "catalog:"
  }
}
